# C4D
*.c4d.bak
# C4D 2026 auto-backup pattern (e.g. foo.c4d@20260504_141554)
*.c4d@*
# Auto-backup directory C4D writes to during dev iterations
scenes/backup/
*.tmp
.DS_Store

# Local dev test scene — autosaves constantly (85MB+ of churn), not a
# reproducible fixture. Kept on disk for the dev loop, out of the repo.
scenes/dev-test.c4d
# Alembic / sim caches and render-log debris dropped into scenes/ during testing
*.abc
scenes/log_*.xml
scenes/frames/

# Python
__pycache__/
*.pyc
.venv/

# Plugin build artifacts
build/
dist/
*.pyp.bak
# Vendor rebuild source — the project-wide `build/` rule above would
# otherwise hide minimp3's headers and our shim, which need to ship so
# the DLL can be rebuilt from clone. Excluded from deployment via
# robocopy /XD build in scripts/deploy.ps1.
!src/vendor/build/
!src/vendor/build/**

# Local-only test audio. Test fixtures for the v7/v8 audio work — kept
# out of the repo because they're large and not redistributable.
scenes/ES_*.wav
scenes/ES_*.mp3

# Editor
.vscode/
.idea/

# Claude Code local harness config
.claude/

# Generated thumbnails (regenerable; uncomment if you want to exclude)
# presets/**/*.gif
# presets/**/*.png

# Local scratch (geometry sanity checks, probes, etc.) — any src/_*.py
src/_*.py
# Underscore-prefixed scratch elsewhere: probe scripts, doc-processing
# spikes, preview renders.
scripts/_*
host/shotblocks/docs/_*
host/shotblocks/web/public/cursors/_preview_*
_hamburger_src.js

# Local working-art folders. The DEPLOYED icons live in src/res/icons/
# and host/.../web/src/icons/ (committed); these are the editable sources.
# Anchored to the repo root: the unanchored pattern also (case-
# insensitively) swallowed host/.../web/public/cursors/, whose PNGs are
# runtime assets for the Mac native cursor layer.
/Cursors/
/Icons/
wizard art/

# Junk throwaway test scenes (random names). The canonical fixture is
# scenes/dev-test.c4d (ignored above); real fixtures get committed by name.
scenes/*.c4d

# Old per-bug debugging handoffs (superseded). Note: HANDOFF.md (no
# suffix) is the live handoff and is NOT matched by this dash pattern.
HANDOFF-*.md
